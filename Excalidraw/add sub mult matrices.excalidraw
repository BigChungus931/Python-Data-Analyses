      "isDeleted": false,
      "boundElements": [],
      "updated": 1776617802575,
      "link": null,
      "locked": false,
      "text": "The determinant tells you whether a matrix is useful or broken for math.\n If it's 0, the matrix is broken — you can't do certain operations with it.",
      "fontSize": 87.19991048177079,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The determinant tells you whether a matrix is useful or broken for math.\n If it's 0, the matrix is broken — you can't do certain operations with it.",
      "autoResize": false,
      "lineHeight": 1.25
    }
